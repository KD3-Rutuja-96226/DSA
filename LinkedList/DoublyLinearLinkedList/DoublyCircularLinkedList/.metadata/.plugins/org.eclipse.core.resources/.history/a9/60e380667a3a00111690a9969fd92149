package com.sunbeam;

public class LinkedList {
	static class Node{
		private int data;
		private Node next;
		private Node prev;
		
		public Node(int data) {
			this.data = data;
			next = null;
			prev = null;
		}
	}
	private Node head;
	private Node tail;
	private int size;
	
	public LinkedList() {
		head = tail = null;
		size = 0;
	}
	public int size() {
		return size;
	}
	public void addFirst(int value) {
		Node newNode = new Node(value);
		if(head == null) {
			head = newNode;
			newNode.next = newNode.prev = newNode;	
		}
		else {

			newNode.next = head;
			newNode.prev = head.prev;
			newNode.prev.next = newNode;
			head.prev = newNode;
			head = newNode;
	
		}
		size++;
	}
	public void addLast(int value) {
		Node newNode = new Node(value);
		if(head == null) {
			head = newNode;
			newNode.next = newNode.prev = newNode;
		}
		else {
			Node trav = head;
			while(trav.next != head)
			{
				trav = trav.next;
			}
			newNode.next = head;
			newNode.prev = trav;
			trav.next = newNode;
			head.prev = newNode;
			
		}
		size++;
	}
	public void addPosition(int pos, int value) {
		Node newNode = new Node(value);
		if(head == null) {
			return;
		}
		else if(pos < 1 || pos > size+1) {
			return;
		}
		else if(pos == 1) {
			addFirst(value);
			return;
		}
		else if(pos == size+1) {
			addLast(value);
			return;
		}
		else {
			Node trav = head;
			int i=1;
			while(i<pos-1) {
				trav = trav.next;
				i++;
			}
			newNode.next = trav.next;
			newNode.prev = trav;
			newNode.next.prev = newNode;
			trav.next = newNode;		
		}
		size++;
	}
	public void deleteFirst() {
		
		head.next.prev = head.prev;
		head.prev.next = head.next;
		head = head.next;

	}
	public void deleteLast() {
		
		head.prev = head.prev.prev;
		head.prev.next = head;
		
	}
	public void deletePosition(int pos) {
		if(head == null) {
			return;
		}
		if(head == tail) {
			head = tail = null;
		}
		else {
			Node trav = head;
			for(int i=1;i<pos;i++) {
				trav = trav.next;
			}
			trav.prev.next = trav.next;
			trav.next.prev = trav.prev;
		}
	}
	public void fdisplay() {
		if(head == null) {
			return;
		}
		Node trav = head;
		System.out.println("Forward List : ");
		do {
			System.out.print(trav.data+" ");
			trav = trav.next;
		}while(trav != head);		
	}
}


